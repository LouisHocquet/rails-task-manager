<h1><%= @task.title.capitalize %></h1>
<div class="pos-abs-top-right">
  <%= link_to "Edit task", edit_task_path, class: "btn btn-outline-primary" %>
</div>
<div class="alert alert-secondary">
  <%= @task.details %>
</div>
<div class="mt-3 mb-3 form-check">
  <% if @task.completed == true %>
    <input class="form-check-input" type="checkbox" id="taskDone" checked>
    <label class="form-check-label" for="taskDone">This task is completed</label>
  <% else %>
    <input class="form-check-input" type="checkbox" id="taskDone">
    <label class="form-check-label" for="taskDone">This task is not completed yet</label>
  <% end %>
</div>
<hr>
<div class="mt-3">
  <%= link_to "Back to tasks", tasks_path %>
</div>