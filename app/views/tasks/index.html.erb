<h1>Tasks</h1>
<div class="form-check">
  <% @tasks.each do |task| %>
    <% if task.completed %>
      <input class="form-check-input" type="checkbox" id=<%= task.title %> checked>
    <% else %>
      <input class="form-check-input" type="checkbox" id=<%= task.title %>>
    <% end %>
    <%= link_to task.title.capitalize, task_path(task) %>
    <br/>
  <% end %>
</div>
